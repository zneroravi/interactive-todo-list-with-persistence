# Frontend Environment Variables
# These variables are used by the React frontend.
# They should be prefixed with REACT_APP_ to be exposed to the browser.

# The base URL for the backend API.
# Example for local development: http://localhost:8000/backend
# Example for production: https://api.yourdomain.com
REACT_APP_API_BASE_URL=http://localhost:8000/backend


# Backend Environment Variables
# These variables are used by the PHP backend for database connection and other configurations.

# Database host. Typically 'localhost' or '127.0.0.1' for local development.
DB_HOST=localhost

# Database name.
DB_NAME=todo_app_db

# Database user.
DB_USER=root

# Database password.
DB_PASS=

# Database character set.
DB_CHARSET=utf8mb4

# Allowed origin for Cross-Origin Resource Sharing (CORS).
# This should match the URL where your React frontend is served.
# For local development, this is typically http://localhost:3000.
# For production, this should be your frontend's domain (e.g., https://yourdomain.com).
CORS_ORIGIN=http://localhost:3000