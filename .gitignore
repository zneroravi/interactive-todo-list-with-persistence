# Node.js / React
# Dependencies
/node_modules

# Build output
/build
/dist
.parcel-cache/ # If using Parcel, though Create React App uses Webpack by default

# Logs
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# Environment variables
# Local environment variables should not be committed to version control.
# A .env.example file is provided for reference.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# PHP
# Composer dependencies
/vendor

# Logs (general for PHP backend)
*.log

# macOS
.DS_Store

# Windows
Thumbs.db

# IDEs and other tools
.vscode/ # VS Code settings (optional, can be committed if shared settings are desired)
.idea/ # IntelliJ / PHPStorm project files
*.sublime-project
*.sublime-workspace